{
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/extract",
      "destination": "/api/extract.ts"
      },
    {
      "source": "/u/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/c/(.*)",
      "destination": "/index.html"
    }
  ]
}
